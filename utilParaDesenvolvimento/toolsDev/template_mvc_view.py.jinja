# modals/{{ class_name | lower | replace('painel', '') }}_view.py
import tkinter as tk
from tkinter import ttk, messagebox
import ttkbootstrap as bstrap

class {{ class_name }}View(bstrap.Toplevel):
    """View (Janela Modal) para {{ panel_name }}."""

    def __init__(self, parent):
        super().__init__(parent)
        self.controller = None
        self.title("Gerenciar {{ panel_name }}")
        self.geometry("700x500")
        self.transient(parent)
        self.grab_set()
        self.resizable(False, False)

        self._create_widgets()
        self._center_window()

    def set_controller(self, controller):
        self.controller = controller

    def _create_widgets(self):
        main_frame = ttk.Frame(self, padding=15)
        main_frame.pack(fill="both", expand=True)

        form_frame = ttk.LabelFrame(main_frame, text=" Formulário ", padding=15)
        form_frame.pack(side="left", fill="y", padx=(0, 10))
        self._create_form(form_frame)

        table_frame = ttk.LabelFrame(main_frame, text=" Registros ", padding=15)
        table_frame.pack(side="right", fill="both", expand=True)
        self._create_table(table_frame)

    # --- Os métodos _create_form, _create_table e os métodos auxiliares
    # --- são praticamente idênticos ao template_mvc_view.py.jinja,
    # --- com a diferença de que não herdam de BasePanel e são um Toplevel.

    def _create_form(self, parent):
        # (Lógica idêntica à View de Painel)
        parent.columnconfigure(1, weight=1)
        {% for col in columns %}
        self.{{ col.name }}_var = tk.StringVar()
        {%- endfor %}
        row_idx = 0
        {% for col in columns if not col.is_pk %}
        ttk.Label(parent, text="{{ col.name.replace('_', ' ').title() }}:").grid(row=row_idx, column=0, sticky="w", pady=3, padx=5)
        {% if col.fk %}
        self.combo_{{ col.name }} = ttk.Combobox(parent, textvariable=self.{{ col.name }}_var, state="readonly", width=25)
        self.combo_{{ col.name }}.grid(row=row_idx, column=1, sticky="ew", padx=5, pady=3)
        {% else %}
        ttk.Entry(parent, textvariable=self.{{ col.name }}_var, width=28).grid(row=row_idx, column=1, sticky="ew", pady=3, padx=5)
        {% endif %}
        row_idx += 1
        {% endfor %}
        btn_frame = ttk.Frame(parent)
        btn_frame.grid(row=row_idx, column=0, columnspan=2, pady=15, sticky="ew")
        ttk.Button(btn_frame, text="Salvar", command=lambda: self.controller.save_item(), style="success.TButton").pack(side="left", expand=True, fill="x", padx=(0,5))
        ttk.Button(btn_frame, text="Excluir", command=lambda: self.controller.delete_item(), style="danger.TButton").pack(side="left", expand=True, fill="x")
        ttk.Button(parent, text="Limpar", command=lambda: self.controller.clear_form(), style="secondary.TButton").grid(row=row_idx+1, column=0, columnspan=2, sticky="ew")

    def _create_table(self, parent):
        # (Lógica idêntica à View de Painel)
        parent.rowconfigure(0, weight=1); parent.columnconfigure(0, weight=1)
        columns = ({%- for col in columns %}'{{ col.name }}'{% if not loop.last %}, {% endif %}{% endfor %})
        self.tree = ttk.Treeview(parent, columns=columns, show='headings', selectmode='browse')
        {% for col in columns %}
        self.tree.heading('{{ col.name }}', text='{{ col.name.replace('_', ' ').title() }}')
        self.tree.column('{{ col.name }}', width={{ 40 if col.is_pk else 120 }}, anchor='w', stretch=True)
        {%- endfor %}
        self.tree.grid(row=0, column=0, sticky="nsew")
        self.tree.bind("<<TreeviewSelect>>", lambda e: self.controller.on_item_select(e))
        scrollbar = ttk.Scrollbar(parent, orient="vertical", command=self.tree.yview)
        self.tree.configure(yscrollcommand=scrollbar.set)
        scrollbar.grid(row=0, column=1, sticky="ns")

    # (Todos os métodos auxiliares como populate_treeview, get_form_data, etc. são idênticos)

    def _center_window(self):
        self.update_idletasks()
        p_x, p_y = self.winfo_toplevel().winfo_rootx(), self.winfo_toplevel().winfo_rooty()
        p_w, p_h = self.winfo_toplevel().winfo_width(), self.winfo_toplevel().winfo_height()
        w, h = self.winfo_width(), self.winfo_height()
        x = p_x + (p_w // 2) - (w // 2)
        y = p_y + (p_h // 2) - (h // 2)
        self.geometry(f"+{x}+{y}")