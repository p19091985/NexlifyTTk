# modals/{{ class_name | lower | replace('painel', '') }}_controller.py
from .{{ class_name | lower | replace('painel', '') }}_view import {{ class_name }}View
from models.{{ class_name | lower | replace('painel', '') }}_model import {{ class_name }}Model

class {{ class_name }}Controller:
    """Controller para a janela modal de {{ panel_name }}."""

    def __init__(self, parent, on_close_callback=None):
        self.model = {{ class_name }}Model()
        self.view = {{ class_name }}View(parent)
        self.view.set_controller(self)
        self.on_close_callback = on_close_callback
        self.selected_item_id = None
        self.load_all_data()

    def show(self):
        """Exibe a janela modal e aguarda seu fechamento."""
        self.view.wait_window()

    def load_all_data(self):
        # (Lógica idêntica ao controller de painel)
        self.load_main_table_data()
        {% if columns | selectattr('fk') | list %}
        self.load_fk_comboboxes()
        {% endif %}

    def load_main_table_data(self):
        try:
            data = self.model.get_all()
            self.view.populate_treeview(data)
        except ConnectionError as e:
            self.view.show_error("Erro de Carga", str(e))
        finally:
            self.clear_form()

    {% if columns | selectattr('fk') | list %}
    def load_fk_comboboxes(self):
        {% for col in columns if col.fk %}
        try:
            fk_data = self.model.get_{{ col.fk.references_table }}_fk_data()
            self.view.populate_{{ col.name }}_combobox(fk_data)
        except Exception:
            self.view.populate_{{ col.name }}_combobox(None)
        {% endfor %}
    {% endif %}

    def save_item(self):
        # (Lógica idêntica ao controller de painel)
        form_data = self.view.get_form_data()
        try:
            self.model.save(form_data, self.selected_item_id)
            msg = "Registro atualizado!" if self.selected_item_id else "Novo registro salvo!"
            self.view.show_info("Sucesso", msg)
            self.load_main_table_data()
            if self.on_close_callback: self.on_close_callback()
        except (ValueError, ConnectionError) as e:
            self.view.show_error("Erro ao Salvar", str(e))

    def delete_item(self):
        # (Lógica idêntica ao controller de painel)
        if not self.selected_item_id:
            self.view.show_warning("Atenção", "Selecione um item para excluir.")
            return
        if self.view.ask_yes_no("Confirmar Exclusão", "Deseja realmente excluir?"):
            try:
                self.model.delete(self.selected_item_id)
                self.view.show_info("Sucesso", "Registro excluído.")
                self.load_main_table_data()
                if self.on_close_callback: self.on_close_callback()
            except ConnectionError as e:
                self.view.show_error("Erro de Exclusão", str(e))

    def on_item_select(self, event=None):
        # (Lógica idêntica ao controller de painel)
        item_data = self.view.get_selected_item_data()
        if item_data:
            self.selected_item_id = item_data['{{ primary_key }}']
            self.view.set_form_data(item_data)
        else:
            self.selected_item_id = None

    def clear_form(self):
        # (Lógica idêntica ao controller de painel)
        self.selected_item_id = None
        self.view.clear_form_fields()